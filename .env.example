# Database
DATABASE_URL=

# Clerk authentication (server)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk publishable key exposed to the client at BUILD time.
# Publishable keys are public by design. Setting this lets the app render
# immediately instead of blocking the first paint on /api/config/clerk
# (a significant mobile LCP win). Set it to the same value as
# CLERK_PUBLISHABLE_KEY. Must be present when running `npm run build`.
VITE_CLERK_PUBLISHABLE_KEY=

# Third-party APIs
OPENAI_API_KEY=
YOUTUBE_API_KEY=
